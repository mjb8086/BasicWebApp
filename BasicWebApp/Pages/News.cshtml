@page
@model NewsModel 
@{
    ViewData["Title"] = "News";
}

<div class="text-center">
    <h1 class="display-4">News</h1>
</div>

<div class="mt-4">
    @foreach (var news in Model.newsItems)
    {
        <h3 class="border-bottom border-light">@news.Title</h3>
        <p>@news.Story</p>
        <div class="text-sm-end">@news.When.ToString("dd/MM/yyyy hh:mm")</div>
    }
</div>

<div>
</div>
